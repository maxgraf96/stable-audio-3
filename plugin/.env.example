# SA3 Variations — release credentials.
#
# Copy this file to `.env` (same directory) and fill in your real values.
# The release scripts source `.env` automatically; `.env` is gitignored so
# your credentials never land on GitHub.
#
# Required only when cutting a signed / notarised release. Local dev
# builds with the default ad-hoc identity ignore everything in here.
#
# Where things come from:
#  - APPLE_ID         : the email you sign into developer.apple.com with.
#  - APPLE_TEAM_ID    : your 10-character Team ID, e.g. ABCDE12345. Visible
#                       at developer.apple.com/account → Membership.
#  - APPLE_APP_PASSWORD : an app-specific password. Generate at
#                       https://appleid.apple.com → Sign-In and Security
#                       → App-Specific Passwords. NOT your iCloud login.
#  - SA3_CODESIGN_IDENTITY : full string returned by
#                       `security find-identity -v -p codesigning`
#                       for your Developer ID Application certificate.
#                       Looks like: Developer ID Application: Your Name (TEAMID)

APPLE_ID="you@example.com"
APPLE_TEAM_ID="XXXXXXXXXX"
APPLE_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"

SA3_CODESIGN_IDENTITY="Developer ID Application: Your Name (XXXXXXXXXX)"
